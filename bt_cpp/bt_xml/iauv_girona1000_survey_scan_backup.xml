<root BTCPP_format="4">
    <BehaviorTree ID="main_bt">
        <Sequence name="iauv_girona1000_survey_scan">
            <SaySomething2 name="scan"    message="request scan" />
            <PathRequest type="scan" survey_type="{survey_type}"/>
            <ReactiveSequence>
                <Fallback>
                    <isPathClear survey_type="{survey_type}"/>
                    <Sequence name="iauv_girona1000_survey_circular"> 
                        <SaySomething2 name="circular"    message="request circular" /> 
                        <PathRequest type="circular" survey_type="{survey_type}"/>
                        <RetryUntilSuccessful num_attempts="5">
                            <Inspect inspection_is_completed="true" survey_type="{survey_type}"/>
                        </RetryUntilSuccessful>
                        <SaySomething2 name="circular"    message="circular success" /> 
                    </Sequence>
                </Fallback>
                <Inspect inspection_is_completed="true" survey_type="{survey_type}"/>
            </ReactiveSequence>
        </Sequence>
    </BehaviorTree>
</root>